{
  "manifest_version": 3,
  "name": "Coverage Lens",
  "version": "1.0",
  "description": "Visualize code coverage directly on your app.",
  "permissions": ["storage", "activeTab"],
  "background": {
    "service_worker": "src/background.ts"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.ts"],
      "css": ["src/styles.css"]
    }
  ],
  "action": {
    "default_popup": "src/popup.html"
  }
}
